{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.dev/schemas/feature.schema.json",
  "title": "Parsed Feature Record",
  "type": "object",
  "required": ["id", "title", "status", "line_start", "line_end"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "status": { "type": "string" },
    "priority": { "type": ["string", "null"] },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tasks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "line_start": { "type": "integer", "minimum": 1 },
    "line_end": { "type": "integer", "minimum": 1 }
  }
}
